{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Scene",
  "description": "Canonical scene representation produced by Phase 1, enriched by Phase 2.",
  "type": "object",
  "required": [
    "scene_id",
    "timing",
    "content"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "Unique scene identifier (e.g. scene_001)"
    },
    "timing": {
      "type": "object",
      "required": [
        "start_time",
        "end_time",
        "duration"
      ],
      "properties": {
        "start_time": {
          "type": "number",
          "description": "Start time in seconds"
        },
        "end_time": {
          "type": "number",
          "description": "End time in seconds"
        },
        "duration": {
          "type": "number",
          "description": "Duration in seconds"
        }
      }
    },
    "content": {
      "type": "object",
      "required": [
        "text",
        "word_count",
        "type"
      ],
      "properties": {
        "text": {
          "type": "string",
          "description": "Raw scene text used for downstream analysis"
        },
        "word_count": {
          "type": "integer",
          "description": "Number of words in the scene text"
        },
        "type": {
          "type": "string",
          "description": "Scene type from segmenter (e.g. screenplay_scene, timestamped_scene)"
        },
        "header": {
          "type": [
            "string",
            "null"
          ],
          "description": "Scene header from script (e.g. INT. KITCHEN - NIGHT)"
        },
        "location": {
          "type": [
            "string",
            "null"
          ],
          "description": "Extracted location or stage area"
        }
      }
    },
    "emotion": {
      "type": [
        "object",
        "null"
      ],
      "description": "Emotion enrichment added by Phase 2",
      "properties": {
        "primary_emotion": {
          "type": "string"
        },
        "primary_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "secondary_emotion": {
          "type": [
            "string",
            "null"
          ]
        },
        "secondary_score": {
          "type": "number"
        },
        "all_scores": {
          "type": "object",
          "description": "Score map of all detected emotions",
          "additionalProperties": {
            "type": "number"
          }
        },
        "method": {
          "type": "string",
          "description": "Detection method used (ml_chunked, keyword, etc.)"
        }
      }
    }
  },
  "additionalProperties": false
}